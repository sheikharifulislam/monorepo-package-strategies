{
  "name": "just-in-time-package",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf .turbo node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@my-workspace/lint-config": "workspace:*",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "prettier": "^3.7.4",
    "turbo": "^2.8.12",
    "typescript": "5.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "rimraf": "^6.1.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
